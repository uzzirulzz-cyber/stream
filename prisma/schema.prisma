// Multi-M3U Sports Streaming Platform
// Prisma schema (SQLite) — adapted from the MongoDB-based spec.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// IPTV playlist source (up to 3 independent M3U URLs).
model Playlist {
  id            String   @id @default(cuid())
  name          String
  url           String   @unique
  /// active | refreshing | error | disabled
  status        String   @default("active")
  channelCount  Int      @default(0)
  onlineCount   Int      @default(0)
  offlineCount  Int      @default(0)
  lastRefreshAt DateTime?
  lastRefreshMs Int      @default(0)
  nextRefreshAt DateTime?
  /// cron-like: every 6 hours by default
  refreshHours  Int      @default(6)
  errorMessage  String?
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  channels Channel[]
  logs     ImportLog[]
}

/// A single channel parsed from an M3U playlist.
model Channel {
  id            String   @id @default(cuid())
  name          String
  displayName   String
  url           String
  logo          String?
  /// auto | manual
  categoryMode  String   @default("auto")
  category      String   @default("Multi Sports")
  subcategory   String?
  country       String?
  language      String?
  tvgId         String?
  tvgName       String?
  groupTitle    String?
  /// online | offline | unknown
  status        String   @default("unknown")
  enabled       Boolean  @default(true)
  featured      Boolean  @default(false)
  trending      Boolean  @default(false)
  liveNow       Boolean  @default(false)
  viewCount     Int      @default(0)
  /// dedupe signature (lowercased name + host)
  signature     String
  sourceId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  playlist Playlist @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  favorites     Favorite[]
  watchHistory  WatchHistory[]
  continueWatching ContinueWatching[]
  subscriptions  ChannelSubscription[]
  notifications  Notification[]
  sponsorships   SponsoredPlacement[]

  @@index([category])
  @@index([subcategory])
  @@index([status])
  @@index([enabled])
  @@index([featured])
  @@index([trending])
  @@index([liveNow])
  @@index([signature])
  @@index([sourceId])
}

/// Hierarchical sports category. parentId empty => top level.
model SportsCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  parentId  String?
  icon      String?
  color     String?
  /// comma-separated keywords used by the auto-mapper
  keywords  String
  /// custom admin-created category
  isCustom  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

/// User with full signup/login authentication.
model User {
  id        String   @id @default(cuid())
  cookie    String   @unique
  email     String?  @unique
  name      String?
  password  String?  // hashed (scrypt) — null for anonymous cookie users
  avatar    String?
  role      String   @default("viewer") // super_admin | admin | moderator | viewer
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  favorites         Favorite[]
  watchHistory      WatchHistory[]
  continueWatching  ContinueWatching[]
  notifications     Notification[]
  channelSubs       ChannelSubscription[]
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  channelId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([userId])
}

model WatchHistory {
  id        String   @id @default(cuid())
  userId    String
  channelId String
  position  Float    @default(0) // seconds
  duration  Float    @default(0) // seconds
  watchedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([userId, watchedAt])
  @@index([channelId])
}

model ContinueWatching {
  id        String   @id @default(cuid())
  userId    String
  channelId String
  position  Float    @default(0)
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  @@unique([userId, channelId])
  @@index([userId])
}

/// User subscribes to a channel to get notified when it goes live.
model ChannelSubscription {
  id        String   @id @default(cuid())
  userId    String
  channelId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([userId])
  @@index([channelId])
}

/// Notification sent to a user (e.g. "Channel X is now live").
model Notification {
  id        String   @id @default(cuid())
  userId    String
  channelId String?
  title     String
  body      String
  /// live | system | new_channel | favorite_live
  type      String   @default("system")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
}

model ImportLog {
  id         String   @id @default(cuid())
  playlistId String
  status     String // success | error | partial
  imported   Int     @default(0)
  duplicates Int     @default(0)
  errors     Int     @default(0)
  message    String?
  createdAt  DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  @@index([playlistId, createdAt])
}

model Setting {
  key   String @id
  value String
}

// ────────────────────────────────────────────────────────────────────────────
// Monetization & Revenue
// ────────────────────────────────────────────────────────────────────────────

/// Ad slot configuration (banner, in-stream, sidebar, sponsored).
model AdSlot {
  id          String   @id @default(cuid())
  name        String
  /// banner-home | banner-category | in-stream | sidebar | sponsored-rail | interstitial
  placement   String
  /// image | video | text
  type        String   @default("image")
  imageUrl    String?
  videoUrl    String?
  targetUrl   String
  headline    String?
  description String?
  cta         String   @default("Learn More")
  /// CPM rate in cents (per 1000 impressions)
  cpmCents    Int      @default(0)
  /// CPC rate in cents (per click)
  cpcCents    Int      @default(0)
  enabled     Boolean  @default(true)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  /// total revenue earned in cents
  revenueCents Int     @default(0)
  startAt     DateTime?
  endAt       DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([placement, enabled])
  @@index([enabled])
}

/// Individual ad impression/click event — drives revenue calculations.
model AdImpression {
  id        String   @id @default(cuid())
  slotId    String
  userId    String?
  /// impression | click
  kind      String
  /// revenue earned in cents for this event
  revenueCents Int   @default(0)
  createdAt DateTime @default(now())

  @@index([slotId, createdAt])
  @@index([kind])
  @@index([createdAt])
}

/// Subscription plan tier.
model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String
  /// free | premium | premium_plus | family
  tier        String   @unique
  priceCents  Int      @default(0)
  currency    String   @default("USD")
  interval    String   @default("month") // month | year
  features    String   @default("")
  /// highlight on pricing card
  popular     Boolean  @default(false)
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]
}

/// A user subscription (active or expired).
model Subscription {
  id        String   @id @default(cuid())
  userId    String
  planId    String
  status    String   @default("active") // active | canceled | expired | past_due
  startedAt DateTime @default(now())
  endsAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan SubscriptionPlan @relation(fields: [planId], references: [id])
  @@index([userId, status])
  @@index([planId])
}

/// Payment record (subscription + ad payouts + one-off).
model Payment {
  id         String   @id @default(cuid())
  userId     String?
  /// subscription | ad_revenue | donation | one_time
  type       String
  amountCents Int
  currency   String   @default("USD")
  status     String   @default("pending") // pending | completed | failed | refunded
  method     String?  // card | paypal | crypto | stripe
  reference  String?
  createdAt  DateTime @default(now())

  @@index([type, status])
  @@index([createdAt])
  @@index([userId])
}

/// Daily revenue aggregate — one row per day, used for charts.
model RevenueDaily {
  id           String   @id
  /// ISO date: YYYY-MM-DD
  date         String
  /// ad_impression | ad_click | subscription | donation | one_time
  source       String
  amountCents  Int      @default(0)
  count        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([date, source])
  @@index([date])
  @@index([source])
}

/// Affiliate link / partner offer — earns commission on clicks + conversions.
model AffiliateLink {
  id          String   @id @default(cuid())
  name        String
  /// betting | merchandise | vpn | streaming_gear | ticketing | fantasy | other
  category    String   @default("other")
  targetUrl   String
  imageUrl    String?
  headline    String
  description String?
  cta         String   @default("Shop Now")
  /// commission per click in cents
  cpcCents    Int      @default(0)
  /// commission per conversion (signup/purchase) in cents
  cpaCents    Int      @default(0)
  enabled     Boolean  @default(true)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  revenueCents Int     @default(0)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, enabled])
  @@index([enabled])
}

/// Donation / tip jar contribution.
model Donation {
  id         String   @id @default(cuid())
  userId     String?
  amountCents Int
  currency   String   @default("USD")
  message    String?
  /// stripe | paypal | crypto | manual
  method     String   @default("manual")
  status     String   @default("completed")
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

/// Sponsored channel placement — paid promotion in rails/grids.
model SponsoredPlacement {
  id        String   @id @default(cuid())
  channelId String
  /// home-rail | category-top | search-top | live-top
  placement String
  /// sponsor name for the "Sponsored" label
  sponsor   String
  /// amount paid in cents
  paidCents Int      @default(0)
  active    Boolean  @default(true)
  startAt   DateTime?
  endAt     DateTime?
  createdAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  @@index([placement, active])
  @@index([channelId])
}

/// Raw traffic event — page views, sessions, unique visitors.
/// Drives the RPM (revenue per mille) + traffic monetization calculator.
model TrafficEvent {
  id        String   @id @default(cuid())
  /// page_view | session_start | channel_view | search
  kind      String
  path      String?
  userId    String?
  country   String?
  device    String?  // desktop | mobile | tablet | tv
  referrer  String?
  createdAt DateTime @default(now())

  @@index([kind, createdAt])
  @@index([createdAt])
  @@index([userId])
}
