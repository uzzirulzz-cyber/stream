# Stream2Arena environment variables
# Copy this file to .env and fill in your values

# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Payrails (real payment processing for VIP subscriptions)
# Get these from your Payrails account manager:
# https://docs.payrails.com/docs/authentication
PAYRAILS_API_KEY=
PAYRAILS_CLIENT_ID=
PAYRAILS_ENV=staging

# Bank Alfalah Hosted Session payment gateway (Pakistan)
# https://sandbox.bankalfalah.com/HS/api/HSAPI/HSAPI
BANKALFALAH_MERCHANT_ID=
BANKALFALAH_STORE_ID=
BANKALFALAH_USERNAME=
BANKALFALAH_PASSWORD=
BANKALFALAH_ENV=sandbox

# JazzCash payment gateway (Pakistan)
# https://sandbox.jazzcash.com.pk/CentralBankPayment/RestGateway/PaymentAPI
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_RETURN_URL=https://yourdomain.com/api/jazzcash/callback
JAZZCASH_ENV=sandbox
